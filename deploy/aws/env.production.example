# Flask / sesiones
COG_SECRET=cambia-esto-por-un-secreto-largo
COG_SESSION_SECURE=1
COG_SESSION_SAMESITE=Lax
HOST=0.0.0.0
PORT=5000
COG_WAITRESS_THREADS=8

# Uploads
COG_MAX_UPLOAD_MB=120
COG_UPLOAD_DEFAULT_MB=20
COG_UPLOAD_ANNUAL_MB=120
COG_UPLOAD_DIR=/app/uploads

# Base de datos (producción recomendada: PostgreSQL / RDS)
COG_DB_ENGINE=postgres
COG_DATABASE_URL=postgresql://worklog:worklog_cambiar@postgres:5432/worklog
# Fallback local si quieres seguir usando SQLite
# COG_DB_PATH=/app/data/cog_work_log.db

# Almacenamiento opcional S3
COG_STORAGE_MODE=local
# COG_STORAGE_MODE=s3
# AWS_REGION=us-east-1
# COG_S3_BUCKET=tu-bucket
# COG_S3_PREFIX=worklog
# COG_S3_ENDPOINT_URL=
# COG_STORAGE_CACHE_LOCAL=1

